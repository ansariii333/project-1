<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GreenLoop | Эко-система будущего</title>
    <style>
        :root {
            --primary: #2ecc71;
            --primary-dark: #27ae60;
            --bg-light: #f8fafc;
            --text-main: #2c3e50;
            --glass: rgba(255, 255, 255, 0.8);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            font-size: 16px;
            color: var(--text-main);
            line-height: 1.6;
            background: linear-gradient(135deg, #e0f2f1 0%, #ffffff 100%);
            background-attachment: fixed;
            min-height: 100vh;
        }

        /* Modern Header with Glassmorphism */
        header {
            position: fixed;
            top: 0;
            width: 100%;
            padding: 15px 0;
            background: var(--glass);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(255,255,255,0.3);
            z-index: 1000;
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        }

        .header-content {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        h1 {
            font-size: 28px;
            color: var(--primary-dark);
            letter-spacing: -1px;
        }

        .header-buttons {
            display: flex;
            gap: 12px;
        }

        /* Modern Buttons */
        .btn {
            padding: 10px 24px;
            border-radius: 50px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            border: none;
            font-size: 14px;
        }

        .btn-primary {
            background-color: var(--primary);
            color: white;
            box-shadow: 0 4px 12px rgba(46, 204, 113, 0.2);
        }

        .btn-primary:hover {
            background-color: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(46, 204, 113, 0.3);
        }

        .btn-outline {
            background: transparent;
            border: 2px solid var(--primary);
            color: var(--primary-dark);
        }

        /* Forms */
        .form-container {
            display: none; /* Controlled by JS */
            max-width: 400px;
            margin: 100px auto 20px auto;
            background: white;
            padding: 30px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            flex-direction: column;
            gap: 15px;
            animation: slideDown 0.4s ease-out;
        }

        input {
            padding: 12px 15px;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            outline: none;
            transition: border-color 0.3s;
        }

        input:focus {
            border-color: var(--primary);
        }

        /* Content Sections */
        section {
            max-width: 1100px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        .map-wrapper {
            margin-top: 100px;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            background: #eee;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin: 40px 0;
        }

        .card {
            background: white;
            padding: 30px;
            border-radius: 20px;
            text-align: center;
            box-shadow: 0 4px 6px rgba(0,0,0,0.02);
            transition: transform 0.3s ease, opacity 0.6s ease, transform 0.6s ease;
            opacity: 0;
            transform: translateY(30px);
        }

        .card.visible {
            opacity: 1;
            transform: translateY(0);
        }

        .card:hover {
            transform: translateY(-5px);
        }

        .card h3 {
            font-size: 32px;
            color: var(--primary-dark);
            margin-bottom: 10px;
        }

        /* Calculator Card Special Style */
        .calc-card {
            background: linear-gradient(135deg, #ffffff 0%, #f0fff4 100%);
            border: 1px solid rgba(46, 204, 113, 0.2);
        }

        #bonusResult {
            margin-top: 15px;
            font-weight: bold;
            color: var(--primary-dark);
            min-height: 24px;
        }

        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @media (max-width: 768px) {
            .header-content { flex-direction: column; gap: 15px; }
            h1 { font-size: 24px; }
        }
    </style>
</head>
<body>

    <header>
        <div class="header-content">
            <div>
                <h1>GreenLoop</h1>
                <p style="font-size: 12px; color: #666;">Сортируй отходы — получай бонусы</p>
            </div>
            <div class="header-buttons">
                <button class="btn btn-outline" onclick="showForm('zapisatsyaForm')">Регистрация</button>
                <button class="btn btn-primary" onclick="showForm('voitiForm')">Войти</button>
            </div>
        </div>
    </header>

    <form id="zapisatsyaForm" class="form-container" onsubmit="submitForm(event)">
        <h3 style="text-align:center">Регистрация</h3>
        <input name="fullname" placeholder="ФИО" required>
        <input name="iin" placeholder="ИИН" maxlength="12" required pattern="\d{12}">
        <input name="contact" placeholder="Телефон" required pattern="\+?\d{10,15}">
        <button type="submit" class="btn btn-primary">Создать аккаунт</button>
    </form>

    <form id="voitiForm" class="form-container" onsubmit="submitForm(event)">
        <h3 style="text-align:center">Вход</h3>
        <input name="iin" placeholder="ИИН" maxlength="12" required pattern="\d{12}">
        <input name="contact" placeholder="Телефон" required pattern="\+?\d{10,15}">
        <button type="submit" class="btn btn-primary">Войти в систему</button>
    </form>

    <section>
        <div class="map-wrapper">
            <iframe src="https://yandex.com/map-widget/v1/?ll=76.8897%2C43.2389&z=12" width="100%" height="450" frameborder="0"></iframe>
        </div>
    </section>

    <section>
        <h2 style="text-align:center; margin-bottom: 30px;">Наши достижения</h2>
        <div class="stats-grid">
            <div class="card">
                <h3>1000+</h3>
                <p>Активных героев</p>
            </div>
            <div class="card">
                <h3>2639 т</h3>
                <p>Переработано</p>
            </div>
            <div class="card">
                <h3>500 т</h3>
                <p>Собрано сегодня</p>
            </div>
            <div class="card calc-card">
                <p>Калькулятор бонусов</p>
                <input type="number" id="wasteAmount" placeholder="Вес (кг)" style="width: 100%; margin: 10px 0;">
                <button onclick="calculateBonus()" class="btn btn-primary" style="width: 100%;">Рассчитать</button>
                <p id="bonusResult"></p>
            </div>
        </div>
    </section>

    <section style="background: rgba(255,255,255,0.4); border-radius: 30px; margin-bottom: 50px;">
        <h2 style="text-align:center; padding-top: 20px;">Эко-новости</h2>
        <div class="stats-grid">
            <div class="card">
                <h4 style="margin-bottom:10px">Субботник в Алматы</h4>
                <p style="font-size: 14px; color: #666;">20 февраля в 10:00. Встречаемся в парке Первого Президента!</p>
            </div>
            <div class="card">
                <h4 style="margin-bottom:10px">Гайд по пластику</h4>
                <p style="font-size: 14px; color: #666;">Маркировки 01 (PET) и 02 (HDPE) теперь принимаются во всех точках.</p>
            </div>
        </div>
    </section>

    <script>
        function showForm(formId){
            // Hide both first
            document.getElementById('zapisatsyaForm').style.display = 'none';
            document.getElementById('voitiForm').style.display = 'none';
            
            // Show selected
            const target = document.getElementById(formId);
            target.style.display = 'flex';
            window.scrollTo({ top: target.offsetTop - 120, behavior: 'smooth' });
        }

        function submitForm(e){
            e.preventDefault();
            alert("Успешно! Мы свяжемся с вами в ближайшее время.");
            e.target.style.display = 'none';
            e.target.reset();
        }

        function calculateBonus(){
            const kg = Number(document.getElementById('wasteAmount').value);
            const res = document.getElementById('bonusResult');
            if(!kg || kg <= 0){
                res.innerText = "Введите вес";
                res.style.color = "red";
                return;
            }
            const bonus = kg * 5;
            res.innerText = `+${bonus} бонусов 🎉`;
            res.style.color = "var(--primary-dark)";
        }

        // Intersection Observer for scroll animations (Better performance)
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.card').forEach(card => observer.observe(card));
    </script>



</body>
</html>


