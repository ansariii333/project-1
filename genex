<script>
function selectRole(role) {
    document.getElementById("patientForm").classList.add("hidden");
    document.getElementById("patientCardScreen").classList.add("hidden");
    document.getElementById("doctorForm").classList.add("hidden");

    if (role === "Patient") document.getElementById("patientForm").classList.remove("hidden");
    if (role === "Doctor") document.getElementById("doctorForm").classList.remove("hidden");
}

function showPatientCard() {
    const name = document.getElementById("pName").value;
    const blood = document.getElementById("pBlood").value;
    const allergy = document.getElementById("pAllergy").value;
    const diagnosis = document.getElementById("pDiagnosis").value;
    const medicine = document.getElementById("pMedicine").value;
    const contact = document.getElementById("pContact").value;

    const card = `
        <p><strong>Имя:</strong> ${name}</p>
        <p><strong>Группа крови:</strong> ${blood}</p>
        <p><strong>Аллергии:</strong> ${allergy}</p>
        <p><strong>Диагноз:</strong> ${diagnosis}</p>
        <p><strong>Лекарства:</strong> ${medicine}</p>
        <p><strong>Контакт:</strong> ${contact}</p>
    `;
    document.getElementById("patientCard").innerHTML = card;

    document.getElementById("patientForm").classList.add("hidden");
    document.getElementById("patientCardScreen").classList.remove("hidden");
}
</script>
