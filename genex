<section>
    <div class = "card">
<h3>Голосовой помощник MVP</h3>
<button id="start">Начать говорить</button>
<p id="output">Текст речи появится здесь...</p>

<script>
  // Проверка браузера
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  const recognition = new SpeechRecognition();

  recognition.lang = 'ru-RU'; // русский язык

  const output = document.getElementById('output');
  const startBtn = document.getElementById('start');

  startBtn.onclick = () => {
    recognition.start();
  }

  recognition.onresult = (event) => {
    const transcript = event.results[0][0].transcript;
    output.innerText = "Вы сказали: " + transcript;

    // Голосовой ответ
    const speech = new SpeechSynthesisUtterance();
    speech.lang = 'ru-RU';
    speech.text = "Вы сказали: " + transcript;
    window.speechSynthesis.speak(speech);
  }

  recognition.onerror = (event) => {
    output.innerText = "Ошибка распознавания: " + event.error;
  }
</script>
</div>
