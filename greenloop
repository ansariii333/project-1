  <script>
    // Конфигурация по умолчанию
    const defaultConfig = {
      site_title: 'GreenLoop',
      hero_title: 'Спасём планету вместе! 🌍',
      hero_subtitle: 'Присоединяйся к экологическому движению. Выполняй задания, зарабатывай баллы и меняй мир!',
      primary_color: '#0d9488',
      secondary_color: '#059669',
      accent_color: '#14b8a6',
      text_color: '#ffffff',
      background_color: '#0f172a'
    };

    let config = { ...defaultConfig };
    let userData = [];
    let userProfile = {
      points: 1580,
      level: 12,
      rank: 47
    };

    // Инициализация Element SDK
    if (window.elementSdk) {
      window.elementSdk.init({
        defaultConfig,
        onConfigChange: async (newConfig) => {
          config = { ...defaultConfig, ...newConfig };
          updateUI();
        },
        mapToCapabilities: (cfg) => ({
          recolorables: [
            {
              get: () => cfg.primary_color || defaultConfig.primary_color,
              set: (v) => { cfg.primary_color = v; window.elementSdk.setConfig({ primary_color: v }); }
            },
            {
              get: () => cfg.background_color || defaultConfig.background_color,
              set: (v) => { cfg.background_color = v; window.elementSdk.setConfig({ background_color: v }); }
            }
          ],
          borderables: [],
          fontEditable: undefined,
          fontSizeable: undefined
        }),
        mapToEditPanelValues: (cfg) => new Map([
          ['site_title', cfg.site_title || defaultConfig.site_title],
          ['hero_title', cfg.hero_title || defaultConfig.hero_title],
          ['hero_subtitle', cfg.hero_subtitle || defaultConfig.hero_subtitle]
        ])
      });
    }

    // Инициализация Data SDK
    const dataHandler = {
      onDataChanged(data) {
        userData = data;
        renderUserData();
      }
    };

    async function initDataSDK() {
      if (window.dataSdk) {
        const result = await window.dataSdk.init(dataHandler);
        if (!result.isOk) {
          console.error('Data SDK init failed');
        }
      }
    }

    initDataSDK();

    // Обновление UI
    function updateUI() {
      const siteTitle = document.getElementById('site-title');
      const heroTitle = document.getElementById('hero-title');
      const heroSubtitle = document.getElementById('hero-subtitle');
      
      if (siteTitle) siteTitle.textContent = config.site_title || defaultConfig.site_title;
      if (heroTitle) heroTitle.textContent = config.hero_title || defaultConfig.hero_title;
      if (heroSubtitle) heroSubtitle.textContent = config.hero_subtitle || defaultConfig.hero_subtitle;
      
      document.body.style.setProperty('--primary-color', config.primary_color || defaultConfig.primary_color);
    }

    function renderUserData() {
      const pointsDisplay = document.getElementById('user-points');
      const profilePoints = document.getElementById('profile-points');
      const ratingPoints = document.getElementById('rating-points');
      
      if (pointsDisplay) pointsDisplay.textContent = userProfile.points.toLocaleString();
      if (profilePoints) profilePoints.textContent = userProfile.points.toLocaleString();
      if (ratingPoints) ratingPoints.textContent = userProfile.points.toLocaleString();
    }

    // Навигация
    function showSection(sectionName) {
      document.querySelectorAll('.section-content').forEach(el => el.classList.add('hidden'));
      document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
      
      const section = document.getElementById(`section-${sectionName}`);
      if (section) section.classList.remove('hidden');
      
      document.querySelectorAll(`[data-section="${sectionName}"]`).forEach(el => el.classList.add('active'));
    }

    // ИИ Ассистент
    let aiOpen = false;
    function toggleAI() {
      const panel = document.getElementById('ai-panel');
      aiOpen = !aiOpen;
      panel.style.transform = aiOpen ? 'translateY(0)' : 'translateY(100%)';
    }

    function sendAIMessage() {
      const input = document.getElementById('ai-input');
      const messages = document.getElementById('ai-messages');
      const text = input.value.trim();
      
      if (!text) return;
      
      // Сообщение пользователя
      messages.innerHTML += `
        <div class="flex gap-3 justify-end chat-bubble">
          <div class="gradient-eco rounded-2xl rounded-tr-none px-4 py-2 max-w-[85%]">
            <p class="text-sm">${text}</p>
          </div>
        </div>
      `;
      
      input.value = '';
      
      // Индикатор набора
      messages.innerHTML += `
        <div class="flex gap-3 typing-msg">
          <div class="w-8 h-8 gradient-eco rounded-lg flex-shrink-0 flex items-center justify-center text-sm">🤖</div>
          <div class="glass rounded-2xl rounded-tl-none px-4 py-2">
            <div class="typing-indicator flex gap-1">
              <span class="w-2 h-2 bg-teal-400 rounded-full"></span>
              <span class="w-2 h-2 bg-teal-400 rounded-full"></span>
              <span class="w-2 h-2 bg-teal-400 rounded-full"></span>
            </div>
          </div>
        </div>
      `;
      
      messages.scrollTop = messages.scrollHeight;
      
      // Ответ ИИ
      setTimeout(() => {
        const typingMsg = messages.querySelector('.typing-msg');
        if (typingMsg) typingMsg.remove();
        
        const responses = [
          'Отличный вопрос! 🌿 Для сортировки мусора используйте разные контейнеры: синий для бумаги, жёлтый для пластика, зелёный для стекла.',
          'Я нашёл 3 точки загрязнения рядом с вами! 📍 Ближайшая в 300м. Хотите построить маршрут?',
          'Сейчас активен челлендж "Эко-неделя"! 🎯 За выполнение вы получите 500 баллов и особый бейдж.',
          'Совет дня: замените пластиковые пакеты на тканевые сумки. Это сократит ваш пластиковый след на 70%! ♻️',
          'Вы уже на 47 месте в рейтинге! 🏆 Ещё 120 баллов до следующей позиции. Продолжайте в том же духе!'
        ];
        
        const response = responses[Math.floor(Math.random() * responses.length)];
        
        messages.innerHTML += `
          <div class="flex gap-3 chat-bubble">
            <div class="w-8 h-8 gradient-eco rounded-lg flex-shrink-0 flex items-center justify-center text-sm">🤖</div>
            <div class="glass rounded-2xl rounded-tl-none px-4 py-2 max-w-[85%]">
              <p class="text-sm">${response}</p>
            </div>
          </div>
        `;
        
        messages.scrollTop = messages.scrollHeight;
      }, 1500);
    }

    // Чат сообщества
    function switchChat(chatType) {
      document.querySelectorAll('.chat-tab').forEach(el => {
        el.classList.remove('gradient-eco');
        el.classList.add('glass');
      });
      document.querySelector(`[data-chat="${chatType}"]`).classList.add('gradient-eco');
      document.querySelector(`[data-chat="${chatType}"]`).classList.remove('glass');
    }

    function sendChatMessage() {
      const input = document.getElementById('chat-input');
      const messages = document.getElementById('chat-messages');
      const text = input.value.trim();
      
      if (!text) return;
      
      const now = new Date();
      const time = now.toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' });
      
      messages.innerHTML += `
        <div class="flex gap-3 justify-end chat-bubble">
          <div class="gradient-eco rounded-2xl rounded-tr-none px-4 py-2 max-w-[80%]">
            <p class="text-sm">${text}</p>
            <p class="text-xs opacity-75 mt-1 text-right">${time} ✓✓</p>
          </div>
          <div class="w-10 h-10 rounded-full gradient-eco flex-shrink-0 flex items-center justify-center">Я</div>
        </div>
      `;
      
      input.value = '';
      messages.scrollTop = messages.scrollHeight;
      
      // Сохраняем в Data SDK
      if (window.dataSdk && userData.length < 999) {
        window.dataSdk.create({
          type: 'chat_message',
          userId: 'current_user',
          chatMessage: text,
          timestamp: new Date().toISOString()
        });
      }
    }

    // Карта и маршруты
    function buildRoute() {
      showToast('🧭 ИИ строит оптимальный маршрут...', 'info');
      setTimeout(() => {
        showToast('✓ Маршрут готов! 3 точки, 2.3 км', 'success');
      }, 1500);
    }

    function startRoute() {
      showToast('🚀 Маршрут начат! Следуйте указаниям', 'success');
      addPoints(20);
    }

    // Отчёт о загрязнении
    function reportPollution() {
      document.getElementById('report-modal').classList.remove('hidden');
    }

    function closeReportModal() {
      document.getElementById('report-modal').classList.add('hidden');
    }

    async function submitReport() {
      const type = document.getElementById('report-type').value;
      const desc = document.getElementById('report-desc').value;
      
      if (window.dataSdk && userData.length < 999) {
        const result = await window.dataSdk.create({
          type: 'pollution_report',
          reportType: type,
          reportLat: 55.75 + Math.random() * 0.1,
          reportLng: 37.62 + Math.random() * 0.1,
          reportStatus: 'new',
          timestamp: new Date().toISOString()
        });
        
        if (result.isOk) {
          closeReportModal();
          showToast('📍 Отчёт отправлен! +50 баллов', 'success');
          addPoints(50);
        } else {
          showToast('Ошибка отправки отчёта', 'error');
        }
      } else if (userData.length >= 999) {
        showToast('Достигнут лимит записей', 'error');
      } else {
        closeReportModal();
        showToast('📍 Отчёт отправлен! +50 баллов', 'success');
        addPoints(50);
      }
    }

    // Челленджи
    function completeChallenge(id) {
      showToast('🎯 Задание выполнено! +30 баллов', 'success');
      addPoints(30);
    }

    // Баллы
    function addPoints(amount) {
      userProfile.points += amount;
      renderUserData();
    }

    // Toast уведомления
    function showToast(message, type = 'info') {
      const container = document.getElementById('toast-container');
      const colors = {
        success: 'bg-green-500',
        error: 'bg-red-500',
        info: 'bg-teal-500'
      };
      
      const toast = document.createElement('div');
      toast.className = `${colors[type]} rounded-xl px-4 py-3 text-sm font-semibold shadow-lg transform translate-y-2 opacity-0 transition-all duration-300`;
      toast.textContent = message;
      container.appendChild(toast);
      
      setTimeout(() => {
        toast.classList.remove('translate-y-2', 'opacity-0');
      }, 10);
      
      setTimeout(() => {
        toast.classList.add('translate-y-2', 'opacity-0');
        setTimeout(() => toast.remove(), 300);
      }, 3000);
    }

    



    // Инициализация
    updateUI();
